{
    "manifest_version": 3,
    "name": "Gesture Suite",
    "version": "1.0.0",
    "description": "Forum layout plus desktop and mobile gestures for Chromium and Kiwi Browser.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "tabs",
        "downloads"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "action": {
        "default_title": "Gesture Suite",
        "default_popup": "ui/popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "content/cookie-bypass/styles.css",
                "content/video-floating/styles.css",
                "content/google-search/styles.css",
                "content/clipboard/styles.css"
            ],
            "js": [
                "shared/namespace.js",
                "shared/config.js",
                "shared/storage.js",
                "shared/runtime.js",
                "shared/tab-actions-client.js",
                "shared/floating-core.js",
                "shared/toast-core.js",
                "shared/selection-core.js",
                "shared/ui-core.js",
                "shared/dom-utils.js",
                "shared/ocr-core.js",
                "content/forum/styles.js",
                "content/forum/layout.js",
                "content/forum/index.js",
                "content/gestures/index.js",
                "content/clipboard/index.js",
                "content/google-search/index.js",
                "content/quick-search/index.js",
                "shared/translate-core.js",
                "content/inline-translate/index.js",
                "content/video-screenshot/index.js",
                "content/trusted-types/index.js",
                "content/youtube-subtitles/index.js",
                "content/cookie-bypass/index.js",
                "content/video-floating/index.js",
                "content/bootstrap.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": ["<all_urls>"],
            "js": ["content/video-floating/page-api.js"],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ]
}