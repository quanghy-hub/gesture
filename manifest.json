{
    "manifest_version": 3,
    "name": "Gesture",
    "version": "1.1.0",
    "description": "Forum layout plus desktop and mobile gestures for Chromium and Kiwi Browser.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "tabs",
        "downloads",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "action": {
        "default_title": "Gesture",
        "default_popup": "ui/popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png"
        }
    }
}
